# =====================================================================
# Datfud — Variables de entorno
# Copia este archivo como .env.local y completa con tus credenciales de Supabase.
# Las encuentras en: Supabase Dashboard -> Project Settings -> API
# =====================================================================

# URL del proyecto Supabase (ej. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Clave pública anónima (publishable / anon key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Clave service role (SOLO server-side, nunca exponer al cliente)
# Se usa para acciones administrativas (registrar tenants, etc.)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# URL pública del sitio (para construir enlaces de QR). En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
